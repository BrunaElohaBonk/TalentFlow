// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum NomeSetor {
  ENGENHARIA
  BDO
  TEF
  BD
  RH
  COMPRAS
  BICO
  CRIN
  LOGISTICA
  QMM
  TOTO
  IMPACT
  FERRAMENTARIA
  PRODUCAO
  BPS
  ETS
  HSE
  ESPAÇO_SAUDE
}

enum NomeSoftskills {
  COMUNICACAO
  TRABALHO_EM_EQUIPE
  LIDERANCA
  EMPATIA
  PROATIVIDADE
  RESOLUCAO_DE_PROBLEMAS
  PENSAMENTO_CRITICO
  GESTAO_DO_TEMPO
  ORGANIZACAO
  CRIATIVIDADE
  NEGOCIACAO
  RESILIENCIA
  ESCUTA_ATIVA
  RESPONSABILIDADE
  AUTONOMIA
  APRENDIZADO_CONTINUO
  INOVACAO
  ORATORIA
  COMPROMETIMENTO
}

enum NivelCompetencia {
  BASICO
  INTERMEDIARIO
  AVANÇADO
}

enum NivelIdioma {
  BASICO
  INTERMEDIARIO
  AVANCADO
  FLUENTE
}

enum NivelFormacao {
  ENSINO_MEDIO
  TECNICO
  GRADUACAO
  POS_GRADUACAO
}

enum TipoUser {
  APRENDIZ
  INSTRUTOR
}

enum Idioma {
  ALEMAO
  ARABE
  COREANO
  ESPANHOL
  FRANCES
  INGLES
  ITALIANO
  JAPONES
  MANDARIM
  RUSSO
  TAILANDES
} 
enum statusCurso {
  CONCLUIDO
  CURSANDO
} 

model User {
  EDV             Int      @id
  tipoUser        TipoUser
  name            String
  data_nascimento DateTime
  user_bosch      String?   @unique
  email_bosch     String?   @unique
  contato         String
  password_login  String
  Ativo           Boolean  @default(true)
  aprendiz        Aprendiz?
  turmas          Turma[]
  resetTokens     TokenRecuperacaoSenha[]
}

model Turma {
  id               Int      @id @default(autoincrement())
  nomeTurma        String
  EDV_Instrutor    Int
  user             User     @relation(fields: [EDV_Instrutor], references: [EDV])
  name_Curso       String
  nomeInstrutor    String
  Ativo            Boolean  @default(true)
  aprendiz         Aprendiz[]
}

model Aprendiz {
  EDV             Int     @id
  user            User    @relation(fields: [EDV], references: [EDV])
  Id_Turma        Int
  turmas          Turma   @relation(fields: [Id_Turma], references: [id])
  profile         Profile?
}

model Profile {
  id                    Int                     @id @default(autoincrement())
  EDV_Aprendiz          Int                     @unique
  aprediz               Aprendiz                @relation(fields: [EDV_Aprendiz], references: [EDV])
  situacao_profissional Situacao_profissional[]
  soft_Skills           Soft_Skills[]
  competencia           Competencia[]
  formacao_Academica    Formacao_Academica[]
  idiomas               Idiomas[]
  cursos                Cursos[]
  historico             PerfilHistorico[]
}

model Situacao_profissional {
  id               Int     @id @default(autoincrement())
  Id_Profile       Int
  profile          Profile @relation(fields: [Id_Profile], references: [id])
  nome_Setor       String? // enun
  nome_Lider       String?
  cumprido_Estagio Boolean @default(false)
  bio_profissional String?
}

model Soft_Skills {
  id              Int     @id @default(autoincrement())
  Id_Profile      Int
  profile         Profile @relation(fields: [Id_Profile], references: [id])
  nome_SoftSkills String // enun
}

model Competencia {
  id                Int     @id @default(autoincrement())
  Id_Profile        Int
  profile           Profile @relation(fields: [Id_Profile], references: [id])
  nome_Competencia  String 
  nivel_Competencia String //enun 
}

model Formacao_Academica {
  id               Int           @id @default(autoincrement())
  Id_Profile       Int
  profile          Profile       @relation(fields: [Id_Profile], references: [id])
  name_Curso       String
  status_Academico statusCurso // enun
  nivel_formacao   NivelFormacao
  periodo_Atual    Int
  total_Periodo    Int
  nome_Institucao  String
}

model Idiomas {
  id           Int         @id @default(autoincrement())
  Id_Profile   Int
  profile      Profile     @relation(fields: [Id_Profile], references: [id])
  nome_Idioma  Idioma 
  nivel_Idioma NivelIdioma
}

model Cursos {
  id             Int      @id @default(autoincrement())
  Id_Profile     Int
  profile        Profile  @relation(fields: [Id_Profile], references: [id])
  name_Curso     String
  status_Cursos  statusCurso 
  data_Conclusao DateTime
  carga_horaria  Int
}

model TokenRecuperacaoSenha {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  expiresAt DateTime
  EDV       Int?
  user      User?     @relation(fields: [EDV], references: [EDV])
  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

model PerfilHistorico {
  Id               Int      @id @default(autoincrement())
  Id_Profile       Int 
  profile          Profile  @relation(fields: [Id_Profile], references: [id])
  dados            Json 
  EDVAlteradoPor   Int?
  DataAlteracao    DateTime @default(now())

}